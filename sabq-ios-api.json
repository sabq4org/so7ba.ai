            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/logout-all",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "logout-all"]
            },
            "body": { "mode": "raw", "raw": "{}" }
          }
        }
      ]
